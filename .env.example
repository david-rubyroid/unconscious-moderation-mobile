# Variables prefixed with EXPO_PUBLIC_ are included in the JS bundle.
# Do NOT put secrets here — use only public keys (e.g. API URLs, analytics IDs).

# API Configuration
# Base URL for the backend API
EXPO_PUBLIC_API_URL=https://api.example.com

# Google OAuth Configuration
# Google OAuth Client ID for iOS
EXPO_PUBLIC_GOOGLE_OAUTH_IOS_CLIENT_ID=your-ios-google-client-id.apps.googleusercontent.com

# Google OAuth Client ID for Android
EXPO_PUBLIC_GOOGLE_OAUTH_ANDROID_CLIENT_ID=your-android-google-client-id.apps.googleusercontent.com

# RevenueCat Configuration
# RevenueCat API Key for iOS
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=your-revenuecat-ios-api-key

# RevenueCat API Key for Android
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=your-revenuecat-android-api-key

# RevenueCat API Key (fallback for web or other platforms)
EXPO_PUBLIC_REVENUECAT_API_KEY=your-revenuecat-api-key

EXPO_PUBLIC_MIXPANEL_TOKEN=token

# OneSignal (push notifications)
# App ID from OneSignal Dashboard: Settings → Keys & IDs
EXPO_PUBLIC_ONESIGNAL_APP_ID=your-onesignal-app-id

# TikTok App Events SDK
# Get these from TikTok Ads Manager → Tools → Business Center → Assets → Apps
# 1. Create iOS app with Bundle ID: com.llc.mydry30
# 2. Copy TikTok App ID (looks like: 759780986137565944)
# 3. Copy App Secret (looks like: TTIORalelwy43mfvlkAdzVKd9Lk2UeFt)
# Instructions: https://ads.tiktok.com/help/article/how-to-integrate-tiktok-app-events-sdk
EXPO_PUBLIC_TIKTOK_APP_ID_IOS=your-tiktok-app-id-ios
EXPO_PUBLIC_TIKTOK_APP_SECRET_IOS=your-tiktok-app-secret-ios
EXPO_PUBLIC_TIKTOK_APP_ID_ANDROID=your-tiktok-app-id-android

# for dev enviriement we have __DEV__ global variable
# EXPO_PUBLIC_BUILD_ENV=preview
# EXPO_PUBLIC_BUILD_ENV=production